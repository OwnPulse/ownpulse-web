const features = [
  {
    title: "Track what actually matters to you",
    description:
      "Peptides, supplements, off-label protocols, sauna, cold plunge — whatever you're doing, OwnPulse tracks it without judgment. No substance name validation. No one deciding what's 'real' health data.",
  },
  {
    title: "Everything on one timeline",
    description:
      "Apple Watch, Oura, Garmin, CGM, labs, interventions, meetings, check-ins — all overlaid on a single time axis. Spot patterns across sources that no single app can show you.",
  },
  {
    title: "Share on your terms",
    description:
      "Keep your data private, or opt in to share with the community. Data sharing is always your choice — per dataset, revocable at any time. Learn from each other's experiments.",
  },
];
---

<section class="py-10 md:py-14 bg-surface">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid md:grid-cols-3 gap-10">
      {features.map((feature) => (
        <div class="border border-neutral-200 rounded-lg bg-surface-elevated p-8">
          <h3 class="text-xl font-bold text-neutral-900 font-display">{feature.title}</h3>
          <p class="mt-3 text-neutral-600 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
