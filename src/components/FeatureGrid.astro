const features = [
  {
    title: "Your data, not theirs",
    description:
      "Health platforms monetize your data. OwnPulse stores it on your infrastructure — self-hosted or in the cooperative's member-governed cloud. You decide who sees it.",
  },
  {
    title: "Everything in one place",
    description:
      "Apple Watch, Oura, Garmin, CGM, labs, interventions, check-ins — all overlaid on a single timeline. See your full picture, not fragments scattered across apps.",
  },
  {
    title: "Benefit from your own data",
    description:
      "Opt in to contribute anonymized insights to research. The cooperative shares 80% of data marketplace revenue with members. The value your data creates flows back to you.",
  },
];
---

<section class="py-20 md:py-28 bg-surface">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid md:grid-cols-3 gap-10">
      {features.map((feature) => (
        <div class="border border-neutral-200 rounded-lg bg-surface-elevated p-8">
          <h3 class="text-xl font-bold text-neutral-900 font-display">{feature.title}</h3>
          <p class="mt-3 text-neutral-600 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
