<section class="relative overflow-hidden bg-surface-elevated">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-24 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <h1 class="text-5xl md:text-5xl font-bold leading-tight tracking-tight text-neutral-900 font-display">
        Every signal.<br/>One&nbsp;timeline.
      </h1>
      <p class="mt-4 text-xl text-primary font-medium font-display">
        Your data. Your health. Your benefit.
      </p>
      <p class="mt-4 text-lg text-neutral-600 leading-relaxed max-w-lg">
        OwnPulse brings together everything that affects your health — wearables, labs, supplements,
        peptides, CGM, sleep, meetings, subjective check-ins — and puts it on a single timeline.
        See the correlations no single app can show you.
      </p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a
          href="#waitlist"
          class="inline-flex items-center rounded-md bg-primary px-6 py-3 text-base font-medium text-white hover:bg-primary-dark transition-colors"
        >
          Get early access
        </a>
        <a
          href="https://github.com/ownpulse/ownpulse"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-md border-2 border-neutral-300 px-6 py-3 text-base font-medium text-neutral-700 hover:border-neutral-500 hover:text-neutral-900 transition-colors"
        >
          View on GitHub
        </a>
      </div>
    </div>

    <!-- Abstract data visualization motif -->
    <div class="hidden md:block" aria-hidden="true">
      <svg viewBox="0 0 540 360" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <!-- Grid lines -->
        <line x1="0" y1="80" x2="480" y2="80" stroke="#deded6" stroke-width="0.5"/>
        <line x1="0" y1="160" x2="480" y2="160" stroke="#deded6" stroke-width="0.5"/>
        <line x1="0" y1="240" x2="480" y2="240" stroke="#deded6" stroke-width="0.5"/>
        <line x1="80" y1="0" x2="80" y2="360" stroke="#deded6" stroke-width="0.5"/>
        <line x1="160" y1="0" x2="160" y2="360" stroke="#deded6" stroke-width="0.5"/>
        <line x1="240" y1="0" x2="240" y2="360" stroke="#deded6" stroke-width="0.5"/>
        <line x1="320" y1="0" x2="320" y2="360" stroke="#deded6" stroke-width="0.5"/>
        <line x1="400" y1="0" x2="400" y2="360" stroke="#deded6" stroke-width="0.5"/>

        <!--
          Story: HRV (primary) and deep sleep (secondary) both improve
          after two interventions. Glucose (tertiary) stays noisy/flat
          — it doesn't correlate, which is realistic.

          Event 1 (~day 5): "Caffeine ≤70mg/day"
          Event 2 (~day 9): "Mg glycinate 400mg before bed"
        -->

        <!-- Primary: HRV (ms) — flat/noisy before event 1, then rising -->
        <polyline
          points="20,195 60,205 100,190 140,200 180,195 220,175 260,160 300,145 340,155 380,130 420,120 460,115"
          stroke="#c2654a"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <linearGradient id="grad-primary" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#c2654a" stop-opacity="0.15"/>
          <stop offset="100%" stop-color="#c2654a" stop-opacity="0"/>
        </linearGradient>
        <polygon
          points="20,195 60,205 100,190 140,200 180,195 220,175 260,160 300,145 340,155 380,130 420,120 460,115 460,280 20,280"
          fill="url(#grad-primary)"
        />

        <!-- Secondary: Deep sleep (hrs) — mirrors HRV improvement -->
        <polyline
          points="20,255 60,260 100,250 140,258 180,252 220,238 260,225 300,215 340,222 380,205 420,198 460,195"
          stroke="#3d8b8b"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
          stroke-dasharray="6 3"
        />

        <!-- Data points on HRV where it notably shifts -->
        <circle cx="220" cy="175" r="4" fill="#c2654a"/>
        <circle cx="380" cy="130" r="4" fill="#c2654a"/>
        <circle cx="460" cy="115" r="4" fill="#c2654a"/>

        <!-- Line labels (right end) -->
        <text x="466" y="110" fill="#c2654a" font-size="9" font-weight="600" font-family="IBM Plex Sans, sans-serif">HRV</text>
        <text x="466" y="190" fill="#3d8b8b" font-size="9" font-weight="600" font-family="IBM Plex Sans, sans-serif">Deep sleep</text>

        <!-- Event 1: Caffeine reduction -->
        <line x1="190" y1="28" x2="190" y2="280" stroke="#c49a3c" stroke-width="1" stroke-dasharray="4 4"/>
        <circle cx="190" cy="28" r="4" fill="#c49a3c"/>
        <text x="196" y="24" fill="#c49a3c" font-size="9" font-family="IBM Plex Sans, sans-serif">Caffeine ≤70mg/day</text>

        <!-- Event 2: Magnesium -->
        <line x1="340" y1="28" x2="340" y2="280" stroke="#c49a3c" stroke-width="1" stroke-dasharray="4 4"/>
        <circle cx="340" cy="28" r="4" fill="#c49a3c"/>
        <text x="346" y="24" fill="#c49a3c" font-size="9" font-family="IBM Plex Sans, sans-serif">Mg glycinate 400mg</text>

        <!-- Tertiary: Glucose (mg/dL) — noisy, doesn't correlate -->
        <polyline
          points="20,305 60,290 100,310 140,295 180,315 220,298 260,308 300,292 340,302 380,310 420,295 460,305"
          stroke="#9c9c93"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <text x="466" y="300" fill="#9c9c93" font-size="9" font-weight="600" font-family="IBM Plex Sans, sans-serif">Glucose</text>
      </svg>
    </div>
  </div>
</section>
