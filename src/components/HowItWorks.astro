const steps = [
  {
    number: "1",
    title: "Connect your sources",
    description:
      "HealthKit, Garmin, Oura, and CGM sync automatically. Google Calendar too — meeting load is health data. Log interventions, check-ins, and anything else manually.",
  },
  {
    number: "2",
    title: "See the full picture",
    description:
      "One timeline with every metric overlaid. HRV, sleep, glucose, supplements, labs, energy scores — aligned on the same time axis. Run your own correlations.",
  },
  {
    number: "3",
    title: "Build your own analysis",
    description:
      "Your health is personalized. OwnPulse gives you the raw data and the tools to explore it your way — not a generic dashboard built for the average person.",
  },
];
---

<section class="py-20 md:py-28 bg-surface-elevated">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-3xl font-bold text-neutral-900 font-display text-center">How it works</h2>
    <div class="mt-14 grid md:grid-cols-3 gap-12">
      {steps.map((step) => (
        <div class="relative">
          <div class="flex items-center gap-4 mb-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-lg font-mono">
              {step.number}
            </span>
            <h3 class="text-xl font-bold text-neutral-900">{step.title}</h3>
          </div>
          <p class="text-neutral-600 leading-relaxed pl-14">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
