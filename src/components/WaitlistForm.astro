<section id="waitlist" class="py-14 md:py-20 bg-neutral-900">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-xl">
      <h2 class="text-3xl font-bold text-white font-display">Get early access</h2>
      <p class="mt-4 text-neutral-400 leading-relaxed">
        We'll reach out when the cooperative-hosted tier opens. No spam, no third-party services — just
        a heads up when it's ready.
      </p>

      <form id="waitlist-form" class="mt-8 space-y-4">
        <div>
          <label for="waitlist-name" class="block text-sm font-medium text-neutral-400 mb-1">
            Name <span class="text-neutral-600">(optional)</span>
          </label>
          <input
            type="text"
            id="waitlist-name"
            name="name"
            autocomplete="name"
            class="w-full rounded-md border border-neutral-700 bg-neutral-800 px-4 py-2.5 text-white placeholder-neutral-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            placeholder="Your name"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-neutral-400 mb-1">
            What describes you? <span class="text-neutral-600">(optional)</span>
          </label>
          <input type="hidden" name="persona" id="waitlist-persona" />
          <div class="flex flex-wrap gap-2">
            <button type="button" data-persona="quantified_self" title="I track everything" class="persona-pill rounded-full border px-3 py-1.5 text-sm transition-colors border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500">Quantified Selfer</button>
            <button type="button" data-persona="biohacker" title="Nootropics, cold plunge, HRV" class="persona-pill rounded-full border px-3 py-1.5 text-sm transition-colors border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500">Biohacker</button>
            <button type="button" data-persona="peptide_pioneer" title="Research compounds &amp; peptides" class="persona-pill rounded-full border px-3 py-1.5 text-sm transition-colors border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500">Peptide Pioneer</button>
            <button type="button" data-persona="iron_scientist" title="Lifting, recovery, body comp" class="persona-pill rounded-full border px-3 py-1.5 text-sm transition-colors border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500">Iron Scientist</button>
            <button type="button" data-persona="health_detective" title="Figuring out what's going on" class="persona-pill rounded-full border px-3 py-1.5 text-sm transition-colors border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500">Health Detective</button>
            <button type="button" data-persona="builder" title="I want to contribute or self-host" class="persona-pill rounded-full border px-3 py-1.5 text-sm transition-colors border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500">Builder</button>
            <button type="button" data-persona="clinician" title="Tracking patients or clients" class="persona-pill rounded-full border px-3 py-1.5 text-sm transition-colors border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500">Clinician</button>
            <button type="button" data-persona="basics" title="Weight, stress, sleep" class="persona-pill rounded-full border px-3 py-1.5 text-sm transition-colors border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500">Just the Basics</button>
          </div>
        </div>
        <div>
          <label for="waitlist-email" class="block text-sm font-medium text-neutral-400 mb-1">
            Email <span class="text-primary">*</span>
          </label>
          <input
            type="email"
            id="waitlist-email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-md border border-neutral-700 bg-neutral-800 px-4 py-2.5 text-white placeholder-neutral-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            placeholder="you@example.com"
          />
        </div>
        <button
          type="submit"
          class="w-full rounded-md bg-primary px-6 py-3 text-base font-medium text-white hover:bg-primary-dark transition-colors"
        >
          Join the waitlist
        </button>
      </form>

      <div id="waitlist-success" class="mt-8 hidden">
        <p class="text-accent-light font-medium">You're on the list — we'll be in touch.</p>
      </div>

      <p class="mt-6 text-sm text-neutral-500">
        Already technical?
        <a
          href="https://github.com/ownpulse/ownpulse/blob/main/docs/guides/self-hosting.md"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent-light hover:text-accent underline"
        >
          Self-host today &rarr;
        </a>
      </p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("waitlist-form") as HTMLFormElement;
  const success = document.getElementById("waitlist-success") as HTMLDivElement;
  const personaInput = document.getElementById("waitlist-persona") as HTMLInputElement;

  const SELECTED = "bg-primary text-white border-primary";
  const UNSELECTED = "border-neutral-700 bg-neutral-800 text-neutral-300 hover:border-neutral-500";

  form.querySelectorAll<HTMLButtonElement>(".persona-pill").forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = btn.dataset.persona!;
      const isDeselect = personaInput.value === value;
      personaInput.value = isDeselect ? "" : value;

      form.querySelectorAll<HTMLButtonElement>(".persona-pill").forEach((b) => {
        SELECTED.split(" ").forEach((c) => b.classList.remove(c));
        UNSELECTED.split(" ").forEach((c) => b.classList.add(c));
      });

      if (!isDeselect) {
        UNSELECTED.split(" ").forEach((c) => btn.classList.remove(c));
        SELECTED.split(" ").forEach((c) => btn.classList.add(c));
      }
    });
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const body = {
      name: data.get("name") || undefined,
      email: data.get("email"),
      persona: data.get("persona") || undefined,
    };

    try {
      const res = await fetch("/api/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => null);
        alert(err?.error || "Something went wrong — please try again.");
        return;
      }
    } catch {
      alert("Network error — please try again.");
      return;
    }

    form.classList.add("hidden");
    success.classList.remove("hidden");
  });
</script>
